### Підключення до бази даних PostgreSQL (Neon)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

### Секрет для підпису JWT-токенів сесії
JWT_SECRET=change_me

### Порт сервера
PORT=3001

### Базова адреса застосунку
APP_URL=http://localhost:3001

### Універсальний адміністратор
ADMIN_EMAIL=admin@varta.com
ADMIN_PASSWORD=change_me

### Токен Telegram-бота (від @BotFather)
TELEGRAM_BOT_TOKEN=123456789:your-telegram-bot-token
